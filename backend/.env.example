# Renomme ce fichier en ".env" et remplis les valeurs

# URL de connexion PostgreSQL (Supabase, Neon, ou local)
# Exemple Supabase : postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studylink

# Clé secrète pour signer les tokens JWT (mets une longue chaîne aléatoire en production)
JWT_SECRET=change_moi_avec_une_valeur_aleatoire_longue

# Port du serveur backend
PORT=4000

# URL du frontend (pour la config CORS)
FRONTEND_URL=http://localhost:5173


# Supabase Storage (requis pour envoyer les fichiers depuis l'espace Admin)
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_SECRET_KEY=VOTRE_CLE_SECRETE_SB_SECRET
# Alternative legacy:
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY
SUPABASE_CONTENT_BUCKET=studylink-content


# WebRTC TURN - recommandé pour les appels audio/vidéo fiables
# Option recommandée: Twilio Network Traversal Service (identifiants temporaires générés par le backend)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_auth_token_twilio
TWILIO_TURN_TTL=3600

# Alternative: serveur TURN statique géré par vous ou un fournisseur
# TURN_URL=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp
# TURN_USERNAME=studylink
# TURN_CREDENTIAL=mot_de_passe_turn
